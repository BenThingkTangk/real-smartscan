{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/search",
      "dest": "/api/search.js"
    },
    {
      "src": "/api/intelligence",
      "dest": "/api/intelligence.js"
    },
    {
      "src": "/api/explain",
      "dest": "/api/explain.js"
    },
    {
      "src": "/api/deals",
      "dest": "/api/deals.js"
    },
    {
      "src": "/api/price-history",
      "dest": "/api/price-history.js"
    },
    {
      "src": "/api/smartcast",
      "dest": "/api/smartcast.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/favicon\\.png",
      "dest": "/public/favicon.png"
    },
    {
      "src": "/((?!api/).*)",
      "dest": "/public/index.html"
    }
  ]
}