{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/search",
      "dest": "/api/search.js"
    },
    {
      "src": "/api/intelligence",
      "dest": "/api/intelligence.js"
    },
    {
      "src": "/api/explain",
      "dest": "/api/explain.js"
    },
    {
      "src": "/api/deals",
      "dest": "/api/deals.js"
    },
    {
      "src": "/api/price-history",
      "dest": "/api/price-history.js"
    },
    {
      "src": "/api/smartcast",
      "dest": "/api/smartcast.js"
    },
    {
      "src": "/api/saved-searches",
      "dest": "/api/saved-searches.js"
    },
    {
      "src": "/api/alerts",
      "dest": "/api/alerts.js"
    },
    {
      "src": "/api/record-price",
      "dest": "/api/record-price.js"
    },
    {
      "src": "/api/analytics",
      "dest": "/api/analytics.js"
    },
    {
      "src": "/api/push-subscribe",
      "dest": "/api/push-subscribe.js"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/public/sitemap.xml"
    },
    {
      "src": "/robots.txt",
      "dest": "/public/robots.txt"
    },
    {
      "src": "/manifest.json",
      "dest": "/public/manifest.json"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/favicon\\.png",
      "dest": "/public/favicon.png"
    },
    {
      "src": "/admin.html",
      "dest": "/public/admin.html"
    },
    {
      "src": "/launch.html",
      "dest": "/public/launch.html"
    },
    {
      "src": "/api/smartcast-upload",
      "dest": "/api/smartcast-upload.js"
    },
    {
      "src": "/api/smartcast-confirm",
      "dest": "/api/smartcast-confirm.js"
    },
    {
      "src": "/((?!api/).*)",
      "dest": "/public/index.html"
    }
  ]
}