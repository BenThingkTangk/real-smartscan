{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/search",
      "dest": "/api/search.js"
    },
    {
      "src": "/api/intelligence",
      "dest": "/api/intelligence.js"
    },
    {
      "src": "/api/explain",
      "dest": "/api/explain.js"
    },
    {
      "src": "/api/deals",
      "dest": "/api/deals.js"
    },
    {
      "src": "/api/price-history",
      "dest": "/api/price-history.js"
    },
    {
      "src": "/api/smartcast",
      "dest": "/api/smartcast.js"
    },
    {
      "src": "/api/saved-searches",
      "dest": "/api/saved-searches.js"
    },
    {
      "src": "/api/alerts",
      "dest": "/api/alerts.js"
    },
    {
      "src": "/api/record-price",
      "dest": "/api/record-price.js"
    },
    {
      "src": "/api/analytics",
      "dest": "/api/analytics.js"
    },
    {
      "src": "/api/push-subscribe",
      "dest": "/api/push-subscribe.js"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/public/sitemap.xml"
    },
    {
      "src": "/robots.txt",
      "dest": "/public/robots.txt"
    },
    {
      "src": "/manifest.json",
      "dest": "/public/manifest.json"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/favicon\\.png",
      "dest": "/public/favicon.png"
    },
    {
      "src": "/admin.html",
      "dest": "/public/admin.html"
    },
    {
      "src": "/launch.html",
      "dest": "/public/launch.html"
    },
    {
      "src": "/api/smartcast-upload",
      "dest": "/api/smartcast-upload.js"
    },
    {
      "src": "/api/smartcast-confirm",
      "dest": "/api/smartcast-confirm.js"
    },
    {
      "src": "/sw.js",
      "dest": "/public/sw.js",
      "headers": {
        "Service-Worker-Allowed": "/"
      }
    },
    {
      "src": "/api/subscribe",
      "dest": "/api/subscribe.js"
    },
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.js"
    },
    {
      "src": "/api/check-alerts",
      "dest": "/api/check-alerts.js"
    },
    {
      "src": "/api/send-email",
      "dest": "/api/send-email.js"
    },
    {
      "src": "/((?!api/).*)",
      "dest": "/public/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/record-price?q=macbook+air+m3",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/record-price?q=iphone+16+pro",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/record-price?q=airpods+pro",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/record-price?q=nike+air+max",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/record-price?q=ps5",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/record-price?q=dyson+v15",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/record-price?q=samsung+65+tv",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/record-price?q=theragun+pro",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/check-alerts",
      "schedule": "0 3 * * *"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}